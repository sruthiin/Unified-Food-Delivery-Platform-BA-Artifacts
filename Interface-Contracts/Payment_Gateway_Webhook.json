{
  "title": "PaymentGatewayClearingWebhookContract",
  "type": "object",
  "required": ["api_endpoint", "transaction_matrix", "payout_distribution_ledger"],
  "properties": {
    "api_endpoint": { "type": "string", "example": "/api/v1/payments/webhook/clearance" },
    "transaction_matrix": {
      "type": "object",
      "properties": {
        "transaction_id": { "type": "string", "example": "TXN-UPI-FOOD-99481A" },
        "gross_charge_value": { "type": "number", "example": 450.00 },
        "gateway_status_flag": { "type": "string", "example": "SUCCESS" }
      }
    },
    "payout_distribution_ledger": {
      "type": "object",
      "properties": {
        "calculated_platform_revenue": { "type": "number", "example": 45.00 },
        "calculated_merchant_payable": { "type": "number", "example": 355.00 }
      }
    }
  }
}
